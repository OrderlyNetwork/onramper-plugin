{
  "name": "@orderly.network/onramper-plugin",
  "version": "0.0.2-alpha.0",
  "description": "Onramper plugin for Orderly",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup && pnpm run build:css",
    "build:css": "tailwindcss build -i src/tailwind.css -o dist/styles.css --minify",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ethers": "^6.15.0"
  },
  "devDependencies": {
    "@swc/cli": "^0.3.12",
    "@swc/core": "^1.4.12",
    "@orderly.network/ts-config": "^0.0.2",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.4",
    "tailwindcss-animate": "^1.0.6",
    "tsup": "^8.5.1",
    "typescript": "^5.1.6"
  },
  "peerDependencies": {
    "@orderly.network/hooks": "3.0.0-beta.0",
    "@orderly.network/plugin-core": "3.0.0-beta.0",
    "@orderly.network/i18n": "3.0.0-beta.0",
    "@orderly.network/types": "3.0.0-beta.0",
    "@orderly.network/ui": "3.0.0-beta.0",
    "@orderly.network/utils": "3.0.0-beta.0",
    "react": ">=18",
    "react-dom": ">=18"
  }
}
